# Copy to .env on the VPS at /var/www/cruzercc/backend/.env
PORT=8080
NODE_ENV=production

# Postgres
DATABASE_URL=postgres://cruzercc:STRONG_PASSWORD@127.0.0.1:5432/cruzercc

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AES-256-GCM key for sensitive card fields. MUST be 32 bytes hex (64 chars).
# Generate: openssl rand -hex 32
CARD_ENCRYPTION_KEY=replace-with-64-hex-chars

# Uploads
UPLOAD_DIR=/var/www/cruzercc/uploads
PUBLIC_UPLOAD_BASE=https://cruzercc.shop/uploads

# CORS
CORS_ORIGIN=https://cruzercc.shop

# Initial admin (used by bootstrap-admin.ts)
ADMIN_EMAIL=samexpoit@gmail.com
ADMIN_PASSWORD=Shovon@5448
ADMIN_USERNAME=admin
