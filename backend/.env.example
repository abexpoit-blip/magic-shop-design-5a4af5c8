# Copy to .env on the VPS at /var/www/cruzercc/backend/.env
PORT=8080
NODE_ENV=production

# Postgres
DATABASE_URL=postgres://USER:STRONG_PASSWORD@127.0.0.1:5432/DBNAME

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# AES-256-GCM key for sensitive card fields. MUST be 32 bytes hex (64 chars).
# Generate: openssl rand -hex 32
CARD_ENCRYPTION_KEY=replace-with-64-hex-chars

# Uploads
UPLOAD_DIR=/var/www/cruzercc/uploads
PUBLIC_UPLOAD_BASE=https://your-domain.example/uploads

# CORS
CORS_ORIGIN=https://your-domain.example

# Initial admin (used by bootstrap-admin.ts) — DO NOT commit real values
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_USERNAME=admin
